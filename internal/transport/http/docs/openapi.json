{
  "openapi": "3.0.3",
  "info": {
    "title": "API сервиса задач",
    "version": "1.2.0",
    "description": "API модуля трекера задач медицинской информационной системы с поддержкой периодических и экстренных задач."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Задачи",
      "description": "Операции с обычными задачами и очередями"
    },
    {
      "name": "Периодические задачи",
      "description": "Шаблоны периодических задач"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "get": {
        "tags": ["Задачи"],
        "summary": "Получить очереди задач",
        "responses": {
          "200": {
            "description": "Очереди задач",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskQueues"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Задачи"],
        "summary": "Создать задачу",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Созданная задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": ["Задачи"],
        "summary": "Получить задачу по ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "responses": {
          "200": {
            "description": "Задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Задачи"],
        "summary": "Обновить задачу",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновленная задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Задачи"],
        "summary": "Удалить задачу",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "responses": {
          "204": {
            "description": "Задача удалена"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/v1/recurring-tasks": {
      "get": {
        "tags": ["Периодические задачи"],
        "summary": "Получить список периодических задач",
        "responses": {
          "200": {
            "description": "Список периодических задач",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RecurringTask"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Периодические задачи"],
        "summary": "Создать периодическую задачу",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecurringTaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Созданная периодическая задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringTask"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/v1/recurring-tasks/{id}": {
      "get": {
        "tags": ["Периодические задачи"],
        "summary": "Получить периодическую задачу по ID",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "responses": {
          "200": {
            "description": "Периодическая задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringTask"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": ["Периодические задачи"],
        "summary": "Обновить периодическую задачу",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRecurringTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновленная периодическая задача",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecurringTask"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Периодические задачи"],
        "summary": "Удалить периодическую задачу",
        "parameters": [
          {
            "$ref": "#/components/parameters/TaskID"
          }
        ],
        "responses": {
          "204": {
            "description": "Периодическая задача удалена"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "TaskID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "format": "int64",
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Некорректный запрос",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFound": {
        "description": "Ресурс не найден",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    },
    "schemas": {
      "CreateTaskRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Подготовить отчет"
          },
          "description": {
            "type": "string",
            "example": "Собрать данные и проверить показатели"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "priority": {
            "type": "string",
            "enum": ["normal", "urgent"],
            "example": "urgent"
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": ["title", "status"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Подготовить отчет"
          },
          "description": {
            "type": "string",
            "example": "Собрать данные и проверить показатели"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "in_progress"
          },
          "priority": {
            "type": "string",
            "enum": ["normal", "urgent"],
            "example": "normal"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 1 },
          "title": { "type": "string", "example": "Подготовить отчет" },
          "description": { "type": "string", "example": "Собрать данные и проверить показатели" },
          "status": { "type": "string", "enum": ["new", "in_progress", "done"], "example": "in_progress" },
          "priority": { "type": "string", "enum": ["normal", "urgent"], "example": "urgent" },
          "queue": { "type": "string", "enum": ["regular", "urgent"], "example": "urgent" },
          "scheduled_for": { "type": "string", "format": "date", "nullable": true, "example": "2026-04-07" },
          "source_recurring_task_id": { "type": "integer", "format": "int64", "nullable": true, "example": 12 },
          "created_at": { "type": "string", "format": "date-time", "example": "2026-04-07T00:00:00Z" },
          "updated_at": { "type": "string", "format": "date-time", "example": "2026-04-07T00:00:00Z" }
        }
      },
      "TaskQueues": {
        "type": "object",
        "properties": {
          "urgent_queue": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Task" }
          },
          "regular_queue": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Task" }
          }
        }
      },
      "Recurrence": {
        "type": "object",
        "required": ["type", "start_date"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["daily", "monthly", "specific_dates", "day_parity"],
            "example": "daily"
          },
          "start_date": {
            "type": "string",
            "format": "date",
            "example": "2026-04-01"
          },
          "every_n_days": {
            "type": "integer",
            "minimum": 1,
            "example": 2
          },
          "day_of_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30,
            "example": 15
          },
          "parity": {
            "type": "string",
            "enum": ["odd", "even"],
            "example": "odd"
          },
          "dates": {
            "type": "array",
            "items": { "type": "string", "format": "date" },
            "example": ["2026-04-07", "2026-04-11"]
          }
        }
      },
      "CreateRecurringTaskRequest": {
        "type": "object",
        "required": ["title", "recurrence"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Обзвон выписанных пациентов"
          },
          "description": {
            "type": "string",
            "example": "Ежедневный контрольный звонок после выписки"
          },
          "priority": {
            "type": "string",
            "enum": ["normal", "urgent"],
            "example": "urgent"
          },
          "recurrence": {
            "$ref": "#/components/schemas/Recurrence"
          }
        }
      },
      "UpdateRecurringTaskRequest": {
        "type": "object",
        "required": ["title", "recurrence"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Обзвон выписанных пациентов"
          },
          "description": {
            "type": "string",
            "example": "Ежедневный контрольный звонок после выписки"
          },
          "priority": {
            "type": "string",
            "enum": ["normal", "urgent"],
            "example": "normal"
          },
          "recurrence": {
            "$ref": "#/components/schemas/Recurrence"
          }
        }
      },
      "RecurringTask": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 12 },
          "title": { "type": "string", "example": "Обзвон выписанных пациентов" },
          "description": { "type": "string", "example": "Ежедневный контрольный звонок после выписки" },
          "priority": { "type": "string", "enum": ["normal", "urgent"], "example": "urgent" },
          "recurrence": { "$ref": "#/components/schemas/Recurrence" },
          "last_generated_for": { "type": "string", "format": "date", "nullable": true, "example": "2026-04-07" },
          "created_at": { "type": "string", "format": "date-time", "example": "2026-04-07T00:00:00Z" },
          "updated_at": { "type": "string", "format": "date-time", "example": "2026-04-07T00:00:00Z" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "task not found" }
        }
      }
    }
  }
}
